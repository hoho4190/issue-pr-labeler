# This file is loaded as-is by .github/workflows/lint-check.yml,
# so all entries except comments/blank lines must use the KEY=VALUE format with no leading whitespace.
# dotenv-linter:off UnorderedKey

# LOG_LEVEL=DEBUG

FILTER_REGEX_EXCLUDE=(coverage|dist|node_modules|\.licenses|tmp|__tests__/local-action/tmp|THIRD_PARTY_LICENSES)/.*
LINTER_RULES_PATH=.

VALIDATE_ALL_CODEBASE=true

VALIDATE_SPELL_CODESPELL=true
VALIDATE_EDITORCONFIG=true

VALIDATE_ENV=true
VALIDATE_JSONC=true
VALIDATE_YAML=true
YAML_CONFIG_FILE=.yamllint.yml
VALIDATE_MARKDOWN=true
MARKDOWN_CONFIG_FILE=.markdownlint.yml

VALIDATE_BASH=true
VALIDATE_SHELL_SHFMT=true
VALIDATE_BASH_EXEC=true

VALIDATE_GITLEAKS=true

VALIDATE_GITHUB_ACTIONS=true
VALIDATE_GITHUB_ACTIONS_ZIZMOR=true
GITHUB_ACTIONS_ZIZMOR_CONFIG_FILE=.github/zizmor.yml
