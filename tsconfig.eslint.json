{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node", "jest"]
  },
  "include": ["__tests__", "src", "scripts", "eslint.config.ts", "jest.config.ts", "rollup.config.ts"]
}
