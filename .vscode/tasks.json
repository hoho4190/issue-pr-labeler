{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Checks: format, lint, typecheck",
      "type": "shell",
      "command": "npm run format:check && npm run lint && npm run typecheck && npm run typecheck:test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "npm: test",
      "type": "shell",
      "command": "npm run test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "npm: all",
      "type": "shell",
      "command": "npm run all",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "npm: licenses:third-party:write",
      "type": "shell",
      "command": "npm run licenses:third-party:write",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Super Linter: lint-all",
      "type": "shell",
      "command": "bash scripts/super-linter/run-super-linter.sh lint-all",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Super Linter: lint-changed",
      "type": "shell",
      "command": "bash scripts/super-linter/run-super-linter.sh lint-changed",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
