{
  "name": "issue-pr-labeler",
  "description": "GitHub Action that automatically labels issues and pull requests based on user-defined rules.",
  "version": "3.1.0",
  "author": {
    "name": "hoho4190",
    "url": "https://github.com/hoho4190"
  },
  "type": "module",
  "private": true,
  "homepage": "https://github.com/hoho4190/issue-pr-labeler",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoho4190/issue-pr-labeler.git"
  },
  "bugs": {
    "url": "https://github.com/hoho4190/issue-pr-labeler/issues"
  },
  "funding": {
    "url": "https://github.com/sponsors/hoho4190"
  },
  "keywords": [
    "github",
    "github-action",
    "issue",
    "pull-request",
    "label",
    "labeler",
    "automation"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": "^24.0.0",
    "npm": "^11.0.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "build": "npm run clean && npm run typecheck && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "build:watch": "npm run build -- --watch",
    "build:ci": "npm run format:check && npm run lint && npm run build",
    "test": "NODE_OPTIONS='--experimental-vm-modules --disable-warning=ExperimentalWarning' npx jest --runInBand",
    "test:ci": "npm run format:check && npm run lint && npm run typecheck && npm run typecheck:test && npm run test",
    "all": "npm run format:check && npm run lint && npm run typecheck:test && npm run test && npm run build",
    "licenses:third-party:write": "node ./scripts/third-party-licenses/regenerate-third-party-licenses.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@octokit/request-error": "^7.1.0",
    "fastq": "^1.20.1",
    "is-glob": "^4.0.3",
    "picomatch": "^4.0.4",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@github/local-action": "^7.0.1",
    "@jest/globals": "^30.4.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/is-glob": "^4.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/picomatch": "^4.0.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.0",
    "ts-jest": "^29.4.11",
    "ts-jest-resolver": "^2.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
